---
import Wordmark from "./Wordmark.astro";
import { links } from "../config";

// Three columns, in the autoloops shape: Product / Connect / a copyright line.
// Every link is verified to resolve; nothing is invented. Discord and X are
// omitted because no handle appears in any source doc: add them to `links` in
// src/config.ts and they render here automatically.
const columns = [
  {
    title: "Product",
    items: [
      // Root-relative, not a bare fragment: the footer also renders on /blog/*.
      { label: "Quickstart", href: "/#quickstart" },
      { label: "Docs", href: links.docs },
      { label: "Blog", href: links.blog },
      { label: "FAQ", href: links.faq },
      { label: "Open Telegraph", href: links.telegraphRepo },
    ],
  },
  {
    title: "Connect",
    items: [
      ...(links.contact ? [{ label: "Contact Us", href: links.contact }] : []),
      { label: "GitHub", href: links.repo },
      ...(links.discord ? [{ label: "Discord", href: links.discord }] : []),
      ...(links.x ? [{ label: "X (Twitter)", href: links.x }] : []),
      ...(links.linkedin ? [{ label: "LinkedIn", href: links.linkedin }] : []),
      { label: "Chouhan Industries", href: links.chouhan },
    ],
  },
  {
    title: "Built on",
    items: [
      { label: "KiCad", href: links.kicad },
      { label: "OpenSpec", href: links.openspec },
    ],
  },
];
---

<footer>
  <div class="wrap">
    <div class="card">
      <div class="top">
        <div class="brand">
          <Wordmark size="0.95rem" />
          <p>
            An open source AI agent that designs, documents, and verifies real
            PCBs.
          </p>
          <a class="llms" href="/llms.txt">llms.txt</a>
        </div>

        <div class="cols">
          {
            columns.map((col) => (
              <div class="col">
                <h2>{col.title}</h2>
                <ul>
                  {col.items.map((i) => (
                    <li>
                      <a href={i.href}>{i.label}</a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>

      <div class="bottom">
        <p>
          <a href={links.license}>Apache-2.0</a>.{" "}
          <span class="ohl">
            Hardware designs referenced here are{" "}
            <a href="https://cern-ohl.web.cern.ch/">CERN-OHL-S v2.0</a>.
          </span>
        </p>
        <p>
          <span class="name">copperhead</span> is a <a href={links.chouhan}
            >Chouhan Industries</a
          > project.
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    padding-block: 40px 56px;
    color: var(--text-dim);
    font-size: 0.88rem;
  }

  /* mastra's footer is a large rounded card: a 2px #1c1c1c border on a slightly
     raised #0a0a0a fill, generous padding, soft 32px corners. */
  .card {
    border: 2px solid #1c1c1c;
    background: #0a0a0a;
    border-radius: 20px;
    padding: 64px 56px 44px;
  }

  .top {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) 2.2fr;
    gap: 56px;
  }

  .brand p {
    margin: 1rem 0 0;
    font-size: 0.85rem;
    max-width: 32ch;
    line-height: 1.6;
  }

  /* Small mono file-reference link, mirroring mastra's footer llms.txt. */
  .brand .llms {
    display: inline-block;
    margin-top: 1.1rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--hairline);
    transition:
      color 0.16s ease,
      text-decoration-color 0.16s ease;
  }

  .brand .llms:hover {
    color: var(--copper-hi);
    text-decoration-color: var(--copper-hi);
  }

  /* Content-width columns packed to the right edge, so the slack sits between
     the brand and the link groups instead of trailing off the end. */
  .cols {
    display: grid;
    grid-template-columns: repeat(3, auto);
    justify-content: end;
    gap: 48px;
  }

  /* h2 because the page already has one h1 and these are real headings;
     styled down to a small label (spec §8 landmark rules) */
  .col h2 {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text);
    margin: 0 0 1rem;
  }

  .col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .col a {
    color: var(--text-dim);
    text-decoration: none;
    font-size: 0.86rem;
  }

  .col a:hover {
    color: var(--text);
  }

  .bottom {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .bottom p {
    margin: 0;
    font-size: 0.78rem;
    color: rgba(154, 154, 154, 0.7);
  }

  .bottom a {
    color: rgba(154, 154, 154, 0.85);
  }

  .bottom a:hover {
    color: var(--text);
  }

  .name {
    color: var(--copper-hi);
  }

  /* Stacked under the brand, right-aligned groups would read as detached from
     it, so they go back to the left edge. */
  /* Stacked under the brand, right-aligned groups would read as detached from
     it, so they go back to the left edge. */
  @media (max-width: 860px) {
    .top {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .cols {
      justify-content: start;
    }
  }

  /* Tighter footer on phones: less card padding, closer rows, smaller gaps. */
  @media (max-width: 560px) {
    footer {
      padding-block: 16px 28px;
    }

    .card {
      border-radius: 16px;
      padding: 24px 18px 20px;
    }

    .top {
      gap: 20px;
    }

    .brand p {
      margin-top: 0.55rem;
    }

    .brand .llms {
      margin-top: 0.7rem;
    }

    .cols {
      grid-template-columns: 1fr 1fr;
      gap: 18px 20px;
    }

    .col h2 {
      margin-bottom: 0.55rem;
    }

    .col ul {
      gap: 0;
    }

    .col a {
      display: inline-block;
      padding-block: 0.18rem;
      line-height: 1.3;
      font-size: 0.9rem;
    }

    .bottom {
      margin-top: 20px;
      padding-top: 18px;
      flex-direction: column;
      gap: 6px;
    }

    /* the licence clause reads better on its own line here */
    .bottom .ohl {
      display: block;
    }
  }
</style>
