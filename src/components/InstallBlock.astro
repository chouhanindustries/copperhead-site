---
// Shared terminal block. Used twice on the page (hero, closing CTA), which is
// the autoloops pattern: the install is never more than one screen away.
// W-3: the copy button copies the exact source lines, so the text lives in a
// data attribute rather than being scraped from the DOM (which carries the
// `$ ` prompt markers).
interface Props {
  lines: string[];
  /** Tighter padding for the hero, where the block sits under the subhead. */
  compact?: boolean;
}
const { lines, compact = false } = Astro.props;
const block = lines.join('\n');
---

<div class:list={['terminal', { compact }]}>
  <!-- hidden until JS wires it up, so it is never a dead control (W-1) -->
  <button class="copy" type="button" data-clip={block} aria-label="Copy to clipboard" hidden>
    <svg class="ic-copy" viewBox="0 0 16 16" width="14" height="14" aria-hidden="true" focusable="false">
      <path
        fill="none"
        stroke="currentColor"
        stroke-width="1.4"
        d="M5.5 5.5V3a1 1 0 0 1 1-1H13a1 1 0 0 1 1 1v6.5a1 1 0 0 1-1 1h-2.5m-8-5H9a1 1 0 0 1 1 1V13a1 1 0 0 1-1 1H2.5a1 1 0 0 1-1-1V6.5a1 1 0 0 1 1-1Z"
      />
    </svg>
    <svg class="ic-done" viewBox="0 0 16 16" width="14" height="14" aria-hidden="true" focusable="false">
      <path fill="none" stroke="currentColor" stroke-width="1.7" d="m2.5 8.5 3.5 3.5 7.5-8" />
    </svg>
  </button>
  <pre><code>{
    lines.map((line) => (
      <span class="line"><span class="prompt" aria-hidden="true">$ </span>{line + '\n'}</span>
    ))
  }</code></pre>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('button.copy').forEach((btn) => {
    btn.hidden = false;
    btn.addEventListener('click', async () => {
      const text = btn.dataset.clip ?? '';
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        // Clipboard API unavailable (insecure context, denied permission)
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.setAttribute('readonly', '');
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
      }
      btn.classList.add('done');
      btn.setAttribute('aria-label', 'Copied');
      setTimeout(() => {
        btn.classList.remove('done');
        btn.setAttribute('aria-label', 'Copy to clipboard');
      }, 2000);
    });
  });
</script>

<style>
  /* mastra's elevated code surface: a raised #171717 fill, a hairline #262626
     frame, soft 12px corners. */
  .terminal {
    position: relative;
    background: #171717;
    border: 1px solid #262626;
    border-radius: 12px;
    padding: 20px 22px;
  }

  .terminal.compact {
    padding: 16px 18px;
  }

  pre {
    margin: 0;
    /* the pre (not the terminal) scrolls, so the copy button stays pinned to
       the corner instead of riding along with long lines */
    overflow-x: auto;
    /* long lines can pass under the button; this keeps the line ends legible
       once scrolled to */
    padding-right: 40px;
  }

  code {
    display: block;
    line-height: 1.75;
    color: var(--text);
  }

  .prompt {
    color: var(--copper);
    user-select: none;
  }

  .copy {
    position: absolute;
    top: 8px;
    right: 8px;
    z-index: 1;
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    padding: 0;
    border-radius: 8px;
    border: 1px solid #262626;
    /* solid surface fill so text scrolling beneath never shows through */
    background: #171717;
    color: var(--text-dim);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
  }

  .copy:hover {
    color: var(--text);
    background: #262626;
    border-color: #333;
  }

  .copy .ic-done {
    display: none;
  }

  .copy.done {
    color: var(--copper);
    border-color: var(--trace);
  }

  .copy.done .ic-copy {
    display: none;
  }

  .copy.done .ic-done {
    display: block;
  }

  @media (max-width: 720px) {
    .terminal {
      padding: 18px 16px;
    }

    /* Smaller type on phone so longer commands fit more comfortably. */
    code {
      font-size: 0.8125rem; /* 13px */
    }

    /* icon-only fits in the corner even at 320px; grow the tap target */
    .copy {
      width: 38px;
      height: 38px;
      top: 6px;
      right: 6px;
    }
  }

  /* Phone: wrap long commands instead of scrolling them off the right edge,
     where the tail (…<api-key>, …brief.md) got clipped and read as broken. The
     hanging indent keeps continuation lines aligned past the "$ " prompt; the
     inherited 40px right padding keeps the first rows clear of the copy button. */
  @media (max-width: 560px) {
    pre {
      overflow-x: visible;
    }

    code {
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      font-size: 0.75rem; /* 12px — narrowest phones */
    }

    .line {
      display: block;
      padding-left: 2ch;
      text-indent: -2ch;
    }
  }
</style>
