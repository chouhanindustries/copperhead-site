---
import Wordmark from './Wordmark.astro';
import { links } from '../config';

// Fixed top bar. Spec §4 called for no header in v1, just a floating GitHub
// link; this replaces it and satisfies W-2 more directly (the CTA is in reach
// at every scroll position). Pure CSS, no JS: the bar is always translucent
// rather than switching state on scroll.
// Plain links, no CTA button: the install block sits in the hero and again in
// the closing CTA, so the bar does not need to carry the primary action.
// Discord renders only once a handle exists in config (it is still empty).
interface Props {
  /** False on subpages, where the brand mark has to navigate rather than scroll. */
  home?: boolean;
}

const { home = true } = Astro.props;

const nav = [
  { label: 'Blog', href: links.blog },
  { label: 'FAQ', href: links.faq },
  { label: 'Docs', href: links.docs },
  ...(links.discord ? [{ label: 'Discord', href: links.discord }] : []),
  { label: 'GitHub', href: links.repo },
];
---

<header class="bar">
  <div class="inner">
    <a class="brand" href={home ? '#top' : '/'}>
      <Wordmark size="0.95rem" />
    </a>

    <nav aria-label="Primary">
      <ul>
        {nav.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>
  </div>
</header>

<style>
  .bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    background: rgba(18, 18, 18, 0.72);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .inner {
    max-width: var(--maxw);
    margin-inline: auto;
    padding: 0 28px;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .brand {
    text-decoration: none;
    display: inline-flex;
    /* keeps the tap target comfortable without changing the mark */
    padding: 6px 0;
  }

  nav {
    margin-left: auto;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 28px;
    margin: 0;
    padding: 0;
  }

  nav a {
    color: var(--text-dim);
    text-decoration: none;
    font-size: 0.88rem;
    white-space: nowrap;
  }

  nav a:hover {
    color: var(--text);
  }

  /* Three or four short links fit at every width, so no hamburger and nothing
     gets hidden; the gaps just tighten and the tap targets grow. */
  @media (max-width: 860px) {
    .inner {
      gap: 12px;
      padding-inline: 20px;
    }

    nav ul {
      gap: 18px;
    }

    nav a {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
    }

    .brand {
      min-height: 44px;
      align-items: center;
    }
  }

  @media (max-width: 420px) {
    nav ul {
      gap: 14px;
    }

    nav a {
      font-size: 0.82rem;
    }
  }
</style>
