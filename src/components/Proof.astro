---
import { links } from '../config';
import { has } from '../assets';

// Board render is not in the repo yet. Render the frame either way so the
// section ships; drop public/open-telegraph.webp in and the image appears.
const render = has.boardRender;
---

<section id="proof">
  <div class="wrap">
    <h2 class="section-title">Proven on real copper.</h2>

    <div class="proof">
      <div class="media">
        {
          render ? (
            <img
              src="/pcb.png"
              alt="Render of the Open Telegraph board, a 40 by 40 mm ESP32-S3 Morse key"
              width="560"
              height="560"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div class="placeholder" aria-hidden="true">
              <span>open-telegraph</span>
            </div>
          )
        }
      </div>

      <div class="body">
        <p>
          Open Telegraph is a pocket-size Morse key: an ESP32-S3, one button, one
          RGB LED, and a battery, designed to live inside a 25 microamp sleep
          budget. It was built with this workflow, and every decision, every trap
          caught, and every file is public.
        </p>
        <p class="actions">
          <a href={links.buildStory}>Read the build story</a>
          <a href={links.telegraphRepo}>Browse the repo</a>
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .proof {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 64px;
    align-items: center;
    margin-top: 4.5rem;
  }

  .media img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 6px;
  }

  .placeholder {
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    border-radius: 6px;
    background: var(--surface);
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 0.78rem;
  }

  .body p {
    color: var(--text-dim);
    font-size: 1rem;
    max-width: 48ch;
  }

  .actions {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    margin: 2rem 0 0;
  }

  @media (max-width: 800px) {
    .proof {
      grid-template-columns: 1fr;
      gap: 36px;
      margin-top: 3.5rem;
    }

    .media {
      max-width: 340px;
    }

    .actions {
      gap: 0.5rem 2rem;
      margin-top: 1.5rem;
    }

    .actions a {
      display: inline-block;
      padding-block: 0.5rem;
    }
  }
</style>
