---
// Wordmark: the fiducial mark (circle plus crosshair ticks, the brand icon
// from the docs branding masters) followed by "copperhead" in lowercase mono,
// matching the official lockup. The mark is aria-hidden and the accessible
// name is supplied by the visually-hidden text so screen readers read
// "copperhead".
interface Props {
  size?: string;
  href?: string;
}
const { size = '1rem', href } = Astro.props;
const Tag = href ? 'a' : 'span';
---

<Tag class="wordmark" style={`font-size:${size}`} {...href ? { href } : {}}>
  <span class="sr-only">copperhead</span>
  <span aria-hidden="true" class="mark">
    <svg class="fiducial" viewBox="4.625 4.625 22.75 22.75" focusable="false">
      <circle cx="16" cy="16" r="5.25" fill="none" stroke="var(--copper)" stroke-width="2.25"
      ></circle>
      <path d="M16 5.75v5M16 21.25v5M5.75 16h5M21.25 16h5" stroke="var(--copper)" stroke-width="2.25"
      ></path>
    </svg>
    copperhead
  </span>
</Tag>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .mark {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
  }
  .fiducial {
    width: 1em;
    height: 1em;
    flex: none;
  }
</style>
